{
  "dataset_name": "ner_test_dataset",
  "version": "1.0",
  "purpose": "HanLP NER专用测试集，覆盖机构/人名/地名/歧义/嵌套/边界场景",
  "ner_model": "HanLP COARSE_ELECTRA_SMALL_ZH",
  "linkable_types": ["ORG", "PERSON", "GPE", "LOC"],
  "samples": [
    {
      "id": "NER_001",
      "text": "国家电网有限公司2024年营收达到3.8万亿元，创历史新高。",
      "expected": [
        {"mention": "国家电网有限公司", "type": "ORG", "start": 0, "end": 8}
      ],
      "scenario": "ORG-标准全称",
      "note": "完整企业名称识别"
    },
    {
      "id": "NER_002",
      "text": "国网在特高压直流输电技术方面取得重大突破。",
      "expected": [
        {"mention": "国网", "type": "ORG", "start": 0, "end": 2}
      ],
      "scenario": "ORG-简称",
      "note": "两字简称识别，挑战：字数短、缺乏上下文线索"
    },
    {
      "id": "NER_003",
      "text": "华为、腾讯、阿里巴巴等科技巨头均布局了AI大模型。",
