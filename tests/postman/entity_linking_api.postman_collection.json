          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "服务启动后应返回healthy及知识库实体数量。"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('包含status', function () { pm.expect(body).to.have.property('status'); });"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "知识库摘要",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/knowledge",
