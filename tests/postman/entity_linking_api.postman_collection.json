    {
      "name": "02 已识别Mention输入（主验收）",
      "item": [
        {
          "name": "基准-默认阈值-功能关闭",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"国家电网发布年度报告。\",\n  \"options\": {\n    \"mentions\": [\n      {\n        \"mention\": \"国家电网\",\n        \"type\": \"ORG\",\n        \"char_start\": 0,\n        \"char_end\": 4,\n        \"confidence\": 1\n      }\n    ],\n    \"nil_threshold\": 0.8,\n    \"enable_coreference\": false,\n    \"enable_llm_fallback\": false,\n    \"linkable_types\": [\n      \"ORG\",\n      \"PERSON\",\n      \"GPE\",\n      \"LOC\"\n    ]\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/link_with_mentions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "link_with_mentions"
              ]
            },
            "description": "任务书主输入：text + 已识别mentions + 配置化知识库。"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('响应包含trace_id、results和stats', function () {",
                  "  pm.expect(body).to.have.property('trace_id').that.is.a('string');",
                  "  pm.expect(body).to.have.property('results').that.is.an('array');",
                  "  pm.expect(body).to.have.property('stats').that.is.an('object');",
                  "});",
                  "if (body.trace_id) { pm.collectionVariables.set('trace_id', body.trace_id); }",
                  "pm.test('结果字段满足当前接口契约', function () {",
                  "  body.results.forEach(function (item) {",
                  "    pm.expect(item).to.have.property('mention');",
                  "    pm.expect(item).to.have.property('entity_id');",
                  "    pm.expect(item).to.have.property('standard_entity');",
                  "    pm.expect(item).to.have.property('confidence');",
                  "    pm.expect(item).to.have.property('is_nil');",
                  "    pm.expect(item).to.have.property('evidence');",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
