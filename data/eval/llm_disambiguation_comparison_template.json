      "confidence": "LLM兜底置信度",
      "reasoning_summary": "LLM输出的简要证据摘要，不记录完整长推理",
      "is_correct": "LLM兜底后是否正确"
    },
    "delta": {
      "changed": "前后结果是否发生变化",
      "improvement_type": "corrected_wrong_entity / corrected_nil / unchanged_correct / unchanged_wrong / regression",
      "confidence_delta": "LLM后置信度 - baseline置信度"
    },
    "review": {
      "reviewer": "复核人",
      "review_status": "accepted / rejected / pending",
